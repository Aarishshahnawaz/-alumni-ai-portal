# Server Configuration
HOST=0.0.0.0
PORT=8001
ENVIRONMENT=development
DEBUG=True

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=AlumniAI Service
VERSION=1.0.0

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs
OPENAI_API_KEY=your-openai-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Database (optional for caching)
REDIS_URL=redis://localhost:6379/0
MONGODB_URL=mongodb://localhost:27017/alumni_ai

# Model Configuration
MODEL_CACHE_DIR=./models
MAX_FILE_SIZE_MB=10
SUPPORTED_FILE_TYPES=pdf,doc,docx,txt

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/alumni_ai.log

# Performance
MAX_WORKERS=4
BATCH_SIZE=32
CACHE_TTL=3600

# Feature Flags
ENABLE_CACHING=True
ENABLE_METRICS=True
ENABLE_GPU=False